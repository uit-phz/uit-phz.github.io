# ============================================
# Agentic Omnichannel Chatbot — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env
#
# Supports 8 channels: Telegram, WhatsApp, Messenger, Instagram, LINE, Viber, Discord, Webchat
# Self-hosted — UNLIMITED contacts and conversations

# ---- General ----
NODE_ENV=production
DOMAIN=yourdomain.com
PROTOCOL=https

# ---- PostgreSQL ----
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=change_me_strong_password_123
POSTGRES_DB=chatbot_platform
DATABASE_URL=postgresql://chatbot:change_me_strong_password_123@localhost:5432/chatbot_platform

# ---- Redis ----
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=change_me_redis_password

# ---- Channel Gateway ----
GATEWAY_PORT=4000
GATEWAY_SECRET=change_me_gateway_webhook_secret


# ============================================
# AI / LLM Configuration (set at least ONE)
# ============================================

# Default AI provider: openai | gemini | claude | deepseek
AI_DEFAULT_PROVIDER=gemini

# Fine-tune AI behavior
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=1000

# ---- OpenAI ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1  # Override for compatible APIs

# ---- Google Gemini ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ---- Anthropic Claude ----
CLAUDE_API_KEY=
# ANTHROPIC_API_KEY=  # Also accepted
CLAUDE_MODEL=claude-3-5-haiku-latest

# ---- DeepSeek ----
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat


# ============================================
# Channel API Keys (configure as needed)
# ============================================

# ---- Facebook / Meta (Messenger + Instagram) ----
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
META_VERIFY_TOKEN=your_custom_verify_token
META_WEBHOOK_SECRET=

# ---- WhatsApp Business API (Meta Cloud API) ----
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=your_custom_wa_verify_token

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ---- Viber ----
VIBER_AUTH_TOKEN=
VIBER_BOT_NAME=MyBot

# ---- LINE Messaging API ----
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ---- Discord ----
DISCORD_BOT_TOKEN=
DISCORD_PREFIX=!bot     # Command prefix for guild messages


# ============================================
# Optional Integrations
# ============================================

# ---- Google Sheets ----
GOOGLE_SERVICE_ACCOUNT_KEY=

# ---- Stripe ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Shopify ----
SHOPIFY_STORE_URL=
SHOPIFY_ACCESS_TOKEN=
